background-color: #141414;
background: rgba(0,0,0,0.7);
foreground: #E3DFDB;
border-color: #4C4F4E;

color0: #3B3B3B;
color1: #101010;
color2: #161412;
color3: #463327;
color4: #393B3B;
color5: #704E3A;
color6: #827A73;
color7: #CEC9C4;
color8: #908C89;
