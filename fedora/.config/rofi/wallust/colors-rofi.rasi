 /* wallust template - colors-rofi */

* {
active-background: #4C4F4E;
active-foreground: #E3DFDB;
normal-background: #141414;
normal-foreground: #E3DFDB;
urgent-background: #95684D;
urgent-foreground: #E3DFDB;

alternate-active-background: #5D4434;
alternate-active-foreground: #E3DFDB;
alternate-normal-background: #141414;
alternate-normal-foreground: #E3DFDB;
alternate-urgent-background: #141414;
alternate-urgent-foreground: #E3DFDB;

selected-active-background: #95684D;
selected-active-foreground: #E3DFDB;
selected-normal-background: #95684D;
selected-normal-foreground: #E3DFDB;
selected-urgent-background: #4C4F4E;
