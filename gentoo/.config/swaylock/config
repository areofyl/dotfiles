# appearance — Nimbus palette, source of truth: ~/.config/nimbus/palette.sh
color=10141a
font=FantasqueSansM Nerd Font Mono
font-size=22

# indicator
indicator-radius=90
indicator-thickness=8
indicator-caps-lock

# colors — matching waybar palette
inside-color=10141a00
inside-clear-color=10141a00
inside-ver-color=10141a00
inside-wrong-color=10141a00

ring-color=5a6470
ring-clear-color=7a9a8a
ring-ver-color=8a95b0
ring-wrong-color=8ab4d0

key-hl-color=7a9a8a
bs-hl-color=8ab4d0

text-color=c4ccd4
text-clear-color=c4ccd4
text-ver-color=8a95b0
text-wrong-color=8ab4d0

line-color=00000000
separator-color=00000000

# behavior
daemonize
ignore-empty-password
show-failed-attempts

# effects (swaylock-effects only, ignored by plain swaylock)
clock
timestr=%I:%M %p
datestr=
effect-blur=8x6
effect-vignette=0.4:0.6
fade-in=0.15
grace=3
