[
    {
        "output": "eDP-1",
        "layer": "top",
        "position": "top",
        "height": 28,
        "margin-top": 0,
        "margin-left": 0,
        "margin-right": 0,
        "margin-bottom": 0,
        "modules-left": ["custom/tag1","custom/tag2","custom/tag3","custom/tag4","custom/tag5","custom/tag6","custom/tag7","custom/tag8","custom/tag9","custom/tag10"],
        "modules-center": ["clock"],
        "modules-right": ["custom/glance", "wireplumber", "network", "custom/bluetooth", "custom/battery", "idle_inhibitor"],

        "custom/glance": {
            "exec": "/home/aarav/.local/bin/glance status",
            "return-type": "json",
            "interval": 5,
            "signal": 9,
            "on-click": "/home/aarav/.local/bin/glance menu",
            "on-click-right": "/home/aarav/.local/bin/glance copy",
            "on-scroll-up": "/home/aarav/.local/bin/glance scroll up",
            "on-scroll-down": "/home/aarav/.local/bin/glance scroll down",
            "tooltip": false
        },

        "custom/tag1":  { "exec": "~/.config/waybar/nimbus-tag.sh eDP-1 1",  "return-type": "json", "signal": 8, "interval": "once", "tooltip": false },
        "custom/tag2":  { "exec": "~/.config/waybar/nimbus-tag.sh eDP-1 2",  "return-type": "json", "signal": 8, "interval": "once", "tooltip": false },
        "custom/tag3":  { "exec": "~/.config/waybar/nimbus-tag.sh eDP-1 3",  "return-type": "json", "signal": 8, "interval": "once", "tooltip": false },
        "custom/tag4":  { "exec": "~/.config/waybar/nimbus-tag.sh eDP-1 4",  "return-type": "json", "signal": 8, "interval": "once", "tooltip": false },
        "custom/tag5":  { "exec": "~/.config/waybar/nimbus-tag.sh eDP-1 5",  "return-type": "json", "signal": 8, "interval": "once", "tooltip": false },
        "custom/tag6":  { "exec": "~/.config/waybar/nimbus-tag.sh eDP-1 6",  "return-type": "json", "signal": 8, "interval": "once", "tooltip": false },
        "custom/tag7":  { "exec": "~/.config/waybar/nimbus-tag.sh eDP-1 7",  "return-type": "json", "signal": 8, "interval": "once", "tooltip": false },
        "custom/tag8":  { "exec": "~/.config/waybar/nimbus-tag.sh eDP-1 8",  "return-type": "json", "signal": 8, "interval": "once", "tooltip": false },
        "custom/tag9":  { "exec": "~/.config/waybar/nimbus-tag.sh eDP-1 9",  "return-type": "json", "signal": 8, "interval": "once", "tooltip": false },
        "custom/tag10": { "exec": "~/.config/waybar/nimbus-tag.sh eDP-1 10", "return-type": "json", "signal": 8, "interval": "once", "tooltip": false },

        "clock": {
            "format": "[{:%I:%M %p}]",
            "format-alt": "[{:%I:%M %p - %A, %B %d, %Y}]",
            "tooltip-format": "<span font_family='FantasqueSansM Nerd Font Mono'>{calendar}</span>",
            "calendar": {
                "mode": "month",
                "mode-mon-col": 12,
                "on-scroll": 1,
                "format": {
                    "months":   "<span color=''><b>{}</b></span>",
                    "days":     "<span color=''>{}</span>",
                    "weekdays": "<span color=''>{}</span>",
                    "today":    "<span color=''><b>{}</b></span>"
                }
            }
        },

        "wireplumber": {
            "format": "[{volume}%]",
            "format-muted": "[muted]",
            "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
            "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%+",
            "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-",
            "tooltip": false
        },

        "network": {
            "format-wifi": "[{essid}]",
            "format-ethernet": "[wired]",
            "format-disconnected": "[offline]",
            "tooltip-format-wifi": "{essid}  {signalStrength}%\n{ipaddr}",
            "tooltip-format-ethernet": "{ifname}\n{ipaddr}",
            "tooltip-format-disconnected": "offline"
        },

        "custom/bluetooth": {
            "exec": "if echo 'show' | bluetoothctl 2>/dev/null | grep -q 'Powered: yes'; then dev=$(echo 'info' | bluetoothctl 2>/dev/null | grep 'Name:' | head -1 | sed 's/.*Name: //' | sed 's/ - Find My//'); if [ -n \"$dev\" ]; then echo '{\"text\": \"['\"$dev\"']\", \"class\": \"connected\"}'; else echo '{\"text\": \"[bt]\", \"class\": \"on\"}'; fi; else echo '{\"text\": \"[--]\", \"class\": \"off\"}'; fi",
            "return-type": "json",
            "interval": 5,
            "tooltip": false
        },

        "idle_inhibitor": {
            "format": "[{icon}]",
            "format-icons": {
                "activated": "+",
                "deactivated": "-"
            },
            "tooltip": false
        },

        "custom/battery": {
            "exec": "~/.config/waybar/nimbus-battery.sh",
            "return-type": "json",
            "interval": 5,
            "tooltip": true
        }
    },
