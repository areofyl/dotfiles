{
    "layer": "top",
    "position": "top",
    "modules-left": ["custom/tags"],
    "modules-center": ["clock"],
    "modules-right": ["memory", "custom/power", "wireplumber", "network", "custom/bluetooth", "battery"],
    "tooltip": false,
    "custom/tags": {
        "exec": "tail -f /tmp/dwl-status | ~/.config/dwl/waybar-tags.sh",
        "return-type": "json",
        "format": "{}",
        "markup": true,
        "exec-on-event": false
    },
    "clock": {
        "format": "{:%I:%M %p}",
        "format-alt": "{:%Y-%m-%d}"
    },
    "battery": {
        "format": "{capacity}%-",
        "format-charging": "{capacity}%+",
        "interval": 30
    },
    "custom/bluetooth": {
        "exec": "if echo 'show' | bluetoothctl 2>/dev/null | grep -q 'Powered: yes'; then dev=$(echo 'info' | bluetoothctl 2>/dev/null | grep 'Name:' | head -1 | sed 's/.*Name: //' | sed 's/ - Find My//'); if [ -n \"$dev\" ]; then echo '{\"text\": \"󰂯 '\"$dev\"'\", \"class\": \"connected\"}'; else echo '{\"text\": \"󰂯\", \"class\": \"on\"}'; fi; else echo '{\"text\": \"󰂲\", \"class\": \"off\"}'; fi",
        "return-type": "json",
        "interval": 5
    },
    "wireplumber": {
        "format": "{volume}%"
    },
    "memory": {
        "format": "{used:0.1f}G",
        "interval": 5
    },
    "custom/power": {
        "exec": "awk '{w=$1/1000000; if(w<0)w=-w; if(w>=10) printf \"{\\\"text\\\":\\\"%dW\\\"}\\n\",w; else printf \"{\\\"text\\\":\\\"%.1fW\\\"}\\n\",w}' /sys/class/power_supply/macsmc-battery/power_now",
        "return-type": "json",
        "interval": 5
    },
    "network": {
        "format-wifi": "{essid}",
        "format-disconnected": "disconnected",
        "format-ethernet": "ethernet"
    }
}
