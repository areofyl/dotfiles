set $mod Mod4
set $term kitty
set $files thunar

output eDP-1 resolution 2560x1600@60Hz position 0 0 scale 1.0
output eDP-1 bg /home/aarav/Pictures/wallpapers/morning_mountains_gruvbox.png fill
output DP-1 enable resolution 2560x1440 position 2560 0

exec_always autotiling
exec swayidle \
    timeout 300 'swaylock -f' \
    timeout 600 'swaymsg "output * power off"' \
    resume 'swaymsg "output * power on"'
exec mako

bindswitch --reload --locked lid:on exec swaylock -f

input type:keyboard {
    xkb_layout us
    xkb_options caps:escape
    repeat_rate 50
    repeat_delay 300
}

input type:touchpad {
    tap enabled
    natural_scroll enabled
    dwt enabled
    accel_profile adaptive
    pointer_accel 0.25
}

input type:pointer {
    natural_scroll enabled
    accel_profile adaptive
    pointer_accel 0.25
}

bindsym Ctrl+Alt+Delete exit
bindsym $mod+q kill
bindsym $mod+Return exec $term
bindsym $mod+f exec $files
bindsym $mod+d exec sh -c 'wmenu-run'
bindsym $mod+x exec swaylock
bindsym $mod+Shift+f fullscreen
bindsym $mod+Ctrl+f fullscreen toggle global
bindsym $mod+space floating toggle
bindsym $mod+Alt+r reload
bindsym $mod+b exec firefox-bin

bindsym $mod+Left focus left
bindsym $mod+Right focus right
bindsym $mod+Up focus up
bindsym $mod+Down focus down

bindsym $mod+Ctrl+Left move left
bindsym $mod+Ctrl+Right move right
bindsym $mod+Ctrl+Up move up
bindsym $mod+Ctrl+Down move down

bindsym $mod+Shift+Left exec ~/.config/sway/smart-resize.sh left 50
bindsym $mod+Shift+Right exec ~/.config/sway/smart-resize.sh right 50
bindsym $mod+Shift+Up exec ~/.config/sway/smart-resize.sh up 50
bindsym $mod+Shift+Down exec ~/.config/sway/smart-resize.sh down 50

bindsym $mod+Shift+i layout toggle split
bindsym $mod+p layout toggle splitv splith

bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

bindsym $mod+Shift+1 move container to workspace number 1; workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2; workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3; workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4; workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5; workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6; workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7; workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8; workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9; workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10; workspace number 10

bindsym $mod+Ctrl+1 move container to workspace number 1
bindsym $mod+Ctrl+2 move container to workspace number 2
bindsym $mod+Ctrl+3 move container to workspace number 3
bindsym $mod+Ctrl+4 move container to workspace number 4
bindsym $mod+Ctrl+5 move container to workspace number 5
bindsym $mod+Ctrl+6 move container to workspace number 6
bindsym $mod+Ctrl+7 move container to workspace number 7
bindsym $mod+Ctrl+8 move container to workspace number 8
bindsym $mod+Ctrl+9 move container to workspace number 9
bindsym $mod+Ctrl+0 move container to workspace number 10

bindsym $mod+Tab workspace next_on_output
bindsym $mod+Shift+Tab workspace prev_on_output
bindsym $mod+period workspace next_on_output
bindsym $mod+comma workspace prev_on_output

bindsym $mod+Shift+u move scratchpad
bindsym $mod+u scratchpad show

floating_modifier $mod normal

bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous
bindsym XF86AudioStop exec playerctl stop

bindsym --locked XF86MonBrightnessUp exec /home/aarav/bin/brightnessctl set +5%
bindsym --locked XF86MonBrightnessDown exec /home/aarav/bin/brightnessctl set 5%-

bindsym --no-repeat $mod+Shift+s exec grim -t jpeg -q 95 -g "$(slurp -b 00000000 -s 00000040)" ~/Pictures/Screenshots/$(date +%Y%m%d_%H%M%S).jpg
bindsym --no-repeat $mod+Print exec grim -t jpeg -q 95 ~/Pictures/Screenshots/$(date +%Y%m%d_%H%M%S).jpg

# ── command center ─────────────────────────────────────────
# super+; enters command mode. keys branch into sub-modes.
# waybar shows current mode as a cheat sheet.

bindsym $mod+semicolon mode "[j]window  [k]system  [l]app  [;]wlim"

mode "[j]window  [k]system  [l]app  [;]wlim" {
    bindsym j mode "[h]←  [j]↓  [k]↑  [l]→  [f]ull  [v]split  [space]float  [q]kill"
    bindsym k mode "[j]lock  [k]reload  [l]+/-bright  [;]+/-vol  [i]mute  [o]exit"
    bindsym l mode "[j]term  [k]browser  [l]files  [;]menu  [i]nvim"
    bindsym semicolon exec ~/bin/wlim; mode "default"
    bindsym Escape mode "default"
    bindsym Return mode "default"
}

mode "[h]←  [j]↓  [k]↑  [l]→  [f]ull  [v]split  [space]float  [q]kill" {
    # focus
    bindsym h focus left
    bindsym j focus down
    bindsym k focus up
    bindsym l focus right
    # move (shift)
    bindsym Shift+h move left
    bindsym Shift+j move down
    bindsym Shift+k move up
    bindsym Shift+l move right
    # resize (ctrl)
    bindsym Ctrl+h exec ~/.config/sway/smart-resize.sh left 50
    bindsym Ctrl+l exec ~/.config/sway/smart-resize.sh right 50
    bindsym Ctrl+k exec ~/.config/sway/smart-resize.sh up 50
    bindsym Ctrl+j exec ~/.config/sway/smart-resize.sh down 50
    # actions
    bindsym f fullscreen; mode "default"
    bindsym Shift+f fullscreen toggle global; mode "default"
    bindsym v layout toggle split; mode "default"
    bindsym space floating toggle; mode "default"
    bindsym q kill; mode "default"
    # workspace jump
    bindsym 1 workspace number 1; mode "default"
    bindsym 2 workspace number 2; mode "default"
    bindsym 3 workspace number 3; mode "default"
    bindsym 4 workspace number 4; mode "default"
    bindsym 5 workspace number 5; mode "default"
    bindsym 6 workspace number 6; mode "default"
    bindsym 7 workspace number 7; mode "default"
    bindsym 8 workspace number 8; mode "default"
    bindsym 9 workspace number 9; mode "default"
    bindsym 0 workspace number 10; mode "default"
    bindsym Escape mode "default"
    bindsym Return mode "default"
}

mode "[j]lock  [k]reload  [l]+/-bright  [;]+/-vol  [i]mute  [o]exit" {
    bindsym j exec swaylock; mode "default"
    bindsym k reload; mode "default"
    bindsym l exec /home/aarav/bin/brightnessctl set +5%
    bindsym Shift+l exec /home/aarav/bin/brightnessctl set 5%-
    bindsym semicolon exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
    bindsym Shift+semicolon exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
    bindsym i exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle; mode "default"
    bindsym o exit
    bindsym Escape mode "default"
    bindsym Return mode "default"
}

mode "[j]term  [k]browser  [l]files  [;]menu  [i]nvim" {
    bindsym j exec $term; mode "default"
    bindsym k exec firefox-bin; mode "default"
    bindsym l exec $files; mode "default"
    bindsym semicolon exec sh -c 'wmenu-run'; mode "default"
    bindsym i exec $term -e nvim; mode "default"
    bindsym Escape mode "default"
    bindsym Return mode "default"
}

default_border pixel 1
gaps inner 8
gaps outer 4

xwayland enable

bar {
    swaybar_command waybar
}
