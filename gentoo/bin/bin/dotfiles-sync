#!/bin/sh
# Auto-sync dotfiles — copies configs to dotfiles repo and commits changes individually.
# Run via cron every hour.

DOTFILES="$HOME/dotfiles/gentoo"

# Map of source -> destination inside dotfiles
sync() {
    src="$1"
    dst="$DOTFILES/$2"
    if [ -e "$src" ]; then
        mkdir -p "$(dirname "$dst")"
        cp -r "$src" "$dst"
    fi
}

# Sync all tracked configs
sync "$HOME/.config/dwl/"          ".config/dwl/"
sync "$HOME/.config/custom-lock/"  ".config/custom-lock/"
sync "$HOME/.config/kitty/"        ".config/kitty/"
sync "$HOME/.config/waybar/"       ".config/waybar/"
sync "$HOME/.config/nvim/"         ".config/nvim/"
sync "$HOME/.config/fastfetch/"    ".config/fastfetch/"
sync "$HOME/.config/swaylock/"     ".config/swaylock/"
sync "$HOME/.config/gtk-3.0/"      ".config/gtk-3.0/"
sync "$HOME/.config/gtk-4.0/"      ".config/gtk-4.0/"
sync "$HOME/.zshrc"                ".zshrc"
sync "$HOME/.gitconfig"            ".gitconfig"
sync "$HOME/bin/"                  "bin/"

# Clean up pycache
rm -rf "$DOTFILES/.config/custom-lock/__pycache__" 2>/dev/null

cd "$HOME/dotfiles" || exit 1

# Check if there are any changes
if git diff --quiet && git diff --cached --quiet && [ -z "$(git ls-files --others --exclude-standard)" ]; then
    exit 0
fi

# Commit each changed file individually
git add -A
for file in $(git diff --cached --name-only); do
    git reset HEAD -- . > /dev/null 2>&1
    git add "$file"
    git commit -m "sync $(echo "$file" | sed 's|gentoo/||')"
done

# Commit any remaining new/untracked files
git add -A
if ! git diff --cached --quiet; then
    for file in $(git diff --cached --name-only); do
        git reset HEAD -- . > /dev/null 2>&1
        git add "$file"
        git commit -m "add $(echo "$file" | sed 's|gentoo/||')"
    done
fi
