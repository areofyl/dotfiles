#!/bin/sh
printf "%s\n" \
"ungoogled-chromium" \
    "btop" \
    "nvim" \
    "thunar" \
    "zathura" \
    "mpv" \
    "airpods" \
    "bluetoothctl" \
    "nmtui" \
| tofi 2>/dev/null | xargs -I{} sh -c '
    case "{}" in
        airpods) bluetoothctl connect F0:04:E1:D6:E5:01 ;;
        ungoogled-chromium) /home/aarav/.local/bin/ungoogled-chromium ;;
        btop|nvim|bluetoothctl|nmtui) kitty {} ;;
        *) {} ;;
    esac
' &
